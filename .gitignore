# ===================================================
# ⚠️ このファイルで除外されているもの
# APIキー・認証情報・生徒の個人情報はGitに含みません
# ===================================================

# --- 認証情報（絶対にアップしない）---
credentials.json      # Google OAuthのクライアントシークレット
token.json            # ログイン済みトークン
.env                  # APIキーなどの秘密情報

# --- 生徒の個人情報 ---
# students/ 以下の実名フォルダは除外
# サンプルフォルダ（サンプル生徒/）とテンプレートは含める
students/*/
!students/サンプル生徒/
!students/サンプル生徒/settings.json
!students/template_settings.json

# --- 自動生成ファイル ---
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# --- 一時ファイル・ログ ---
*.log
traceback_log.txt
err.txt
error.log
output.txt
result.txt
courses.txt
temp_worksheet.*

# --- 参考書PDF（著作権・容量） ---
参考書/
*.pdf

# --- OS固有ファイル ---
.DS_Store
Thumbs.db
