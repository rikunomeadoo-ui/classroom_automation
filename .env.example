# =====================================================
# このファイルをコピーして ".env" という名前で保存し、
# 各項目を自分のものに書き換えてください。
# .env ファイルは絶対にGitHubに上げないでください！
# =====================================================

# ---- Gemini API設定 ----
# Google AI Studio (https://aistudio.google.com) でAPIキーを取得してください。
GEMINI_API_KEY="ここにGemini APIキーを貼り付け"

# ------ カレンダー設定 -------
# Googleカレンダーで「塾の授業カレンダー」の設定画面から「カレンダーID」をコピーしてください。
# 例: example@group.calendar.google.com
TARGET_CALENDAR_ID="ここにカレンダーIDを貼り付け"

# ------ Google Meet URL -------
# 授業で使うGoogle MeetのURLを設定してください。
MEET_URL="https://meet.google.com/xxx-xxxx-xxx"

# ------ 担当者設定 -------
# Classroomに投稿されるお知らせに表示される担当者名を設定してください。
# 例: TEACHER_NAME="山田 太郎"
TEACHER_NAME="担当講師名"

# ------ 通知タイミング設定 -------
# 授業開始の何分前にClassroomへ通知を投稿するか設定してください。
# 例: 60 = 1時間前、30 = 30分前、120 = 2時間前
NOTIFY_MINUTES_BEFORE=60
